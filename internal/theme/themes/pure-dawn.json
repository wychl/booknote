{
  "id": "pure-dawn",
  "name": "极简晨光",
  "description": "明亮纯白背景，天空蓝强调色，适合干货、商业类书籍",
  "variables": {
    "--od-color-bg": "#f0f4f8",
    "--od-color-surface": "#ffffff",
    "--od-color-primary": "#3b82f6",
    "--od-color-primary-dark": "#2563eb",
    "--od-color-secondary": "#60a5fa",
    "--od-color-hover": "#60a5fa",
    "--od-color-link": "#3b82f6",
    "--od-color-divider": "#e2e8f0",
    "--od-color-text-high": "#0f172a",
    "--od-color-text-medium": "#1e293b",
    "--od-color-text-low": "#64748b",
    "--od-color-surface-accent": "color-mix(in srgb, var(--od-color-primary) 15%, var(--od-color-surface))",
    "--od-color-highlight": "#fbbf24",
    "--od-color-success": "#10b981",
    "--od-color-error": "#ef4444",
    "--od-color-warning": "#f59e0b",
    "--od-space-xs": "10px",
    "--od-space-sm": "20px",
    "--od-space-md": "32px",
    "--od-space-lg": "48px",
    "--od-space-xl": "64px",
    "--od-radius-sm": "12px",
    "--od-radius-md": "24px",
    "--od-radius-lg": "36px",
    "--od-radius-full": "999px",
    "--od-font-display": "\"Noto Serif SC\", \"Source Han Serif SC\", \"STSong\", \"SimSun\", Georgia, serif",
    "--od-font-body": "system-ui, -apple-system, \"PingFang SC\", \"Microsoft YaHei\", \"Helvetica Neue\", sans-serif",
    "--od-font-mono": "\"JetBrains Mono\", \"SF Mono\", Menlo, monospace",    
    "--od-font-weight-regular": "400",
    "--od-font-weight-medium": "500",
    "--od-font-weight-bold": "700",
    "--od-font-size-0": "120px",
    "--od-font-size-1": "84px",
    "--od-font-size-2": "44px",
    "--od-font-size-3": "36px",
    "--od-font-size-4": "30px",
    "--od-font-size-5": "26px",
    "--od-line-height-tight": "1.25",
    "--od-line-height-body": "1.65",
    "--od-letter-spacing-display": "0.04em",
    "--od-letter-spacing-body": "0.02em",
    "--od-letter-spacing-wide": "0.12em",
    "--od-shadow-card": "0 24px 40px -14px rgba(0, 0, 0, 0.85)",
    "--od-shadow-modal": "0 32px 64px -16px rgba(0, 0, 0, 0.9)",
    "--od-transition-fast": "0.15s ease",
    "--od-transition-base": "0.25s ease",
    "--od-transition-slow": "0.4s ease"
  }
}
    "--od-font-display": "\"Noto Serif SC\", \"Source Han Serif SC\", \"STSong\", \"SimSun\", Georgia, serif",
    "--od-font-body": "system-ui, -apple-system, \"PingFang SC\", \"Microsoft YaHei\", \"Helvetica Neue\", sans-serif",
    "--od-font-mono": "\"JetBrains Mono\", \"SF Mono\", Menlo, monospace",
    "--od-font-weight-regular": "400",
    "--od-font-weight-medium": "500",
    "--od-font-weight-bold": "700",
    "--od-font-size-0": "120px",
    "--od-font-size-1": "84px",
    "--od-font-size-2": "34px",

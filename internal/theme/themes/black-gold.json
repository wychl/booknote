    "--od-color-text-medium": "#e5e5e5",
    "--od-color-text-low": "#a3a3a3",
    "--od-color-highlight": "#fbbf24",
    "--od-color-success": "#8bc34a",
    "--od-color-error": "#e57373",
    "--od-color-warning": "#ffb74d",
    "--od-space-xs": "12px",
    "--od-space-sm": "24px",
    "--od-space-md": "32px",
    "--od-space-lg": "48px",
    "--od-space-xl": "64px",
    "--od-radius-sm": "12px",
    "--od-radius-md": "24px",
    "--od-radius-lg": "36px",

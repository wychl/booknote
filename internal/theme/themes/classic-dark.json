{
  "id": "classic-dark",
  "name": "经典深色 · 精修版",
  "description": "纯黑底深色主题，极致对比，适合深夜阅读与长时间使用",
  "variables": {
    "--od-color-bg": "#000000",
    "--od-color-surface": "#0a0a0a",
    "--od-color-surface-accent": "color-mix(in srgb, var(--od-color-primary) 12%, var(--od-color-surface))",
    "--od-color-primary": "#7aa2f7",
    "--od-color-primary-bright": "#9cbaff",
    "--od-color-primary-dark": "#5a7ec7",
    "--od-color-primary-glow": "color-mix(in srgb, var(--od-color-primary) 18%, transparent)",
    "--od-color-secondary": "#9aa9b9",
    "--od-color-hover": "#3b82f6",
    "--od-color-link": "#7aa2f7",
    "--od-color-divider": "#2a2a2a",
    "--od-color-text-high": "#ffffff",
    "--od-color-text-medium": "#e0e0e0",
    "--od-color-text-low": "#a0a0a0",
    "--od-color-highlight": "#f2c94c",
    "--od-color-success": "#9ece6a",
    "--od-color-error": "#f7768e",
    "--od-color-warning": "#e0af68",
    "--od-space-xs": "10px",
    "--od-space-sm": "20px",
    "--od-space-md": "32px",
    "--od-space-lg": "48px",
    "--od-space-xl": "64px",
    "--od-radius-sm": "12px",
    "--od-radius-md": "24px",
    "--od-radius-lg": "36px",
    "--od-radius-full": "999px",
    "--od-font-display": "-apple-system, \"Inter\", \"SF Pro Display\", system-ui, sans-serif",
    "--od-font-body": "system-ui, -apple-system, \"PingFang SC\", \"Microsoft YaHei\", \"Helvetica Neue\", sans-serif",
    "--od-font-mono": "\"JetBrains Mono\", \"SF Mono\", Menlo, monospace",
    "--od-font-weight-regular": "400",
    "--od-font-weight-medium": "500",
    "--od-font-weight-bold": "700",
    "--od-font-size-0": "120px",
    "--od-font-size-1": "84px",
    "--od-font-size-2": "44px",
    "--od-font-size-3": "36px",
    "--od-font-size-4": "30px",
    "--od-font-size-5": "26px",
    "--od-line-height-tight": "1.25",
    "--od-line-height-body": "1.65",
    "--od-letter-spacing-display": "0.04em",
    "--od-letter-spacing-body": "0.02em",
    "--od-letter-spacing-wide": "0.12em",
    "--od-shadow-card": "0 24px 40px -14px rgba(0, 0, 0, 0.85)",
    "--od-shadow-modal": "0 32px 64px -16px rgba(0, 0, 0, 0.9)",
    "--od-transition-fast": "0.15s ease",
    "--od-transition-base": "0.25s ease",
    "--od-transition-slow": "0.4s ease"
  }
}